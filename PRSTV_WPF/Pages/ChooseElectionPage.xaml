<Page x:Class="PRSTV_WPF.Pages.ChooseElectionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PRSTV_WPF.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ChooseElectionPage">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock FontSize="24" FontWeight="SemiBold" Text="Choose an election" />
            <TextBlock Margin="0,6,0,0" Foreground="{StaticResource Brush.TextSecondary}" TextWrapping="Wrap"
                   Text="Pick an election. If it already has a count in progress you can resume; otherwise you'll be asked to review doubtful ballots before starting." />
        </StackPanel>

        <Border Grid.Row="2" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DockPanel>
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Available elections" DockPanel.Dock="Left" />
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                        <Button Style="{StaticResource SecondaryButton}" MinWidth="140" Margin="0,0,12,0"
                            Content="Refresh" Command="{Binding RefreshCommand}" />
                        <Button Style="{StaticResource SecondaryButton}" MinWidth="140"
                            Content="Back" Command="{Binding BackCommand}" />
                    </StackPanel>
                </DockPanel>

                <TextBlock Grid.Row="2" Margin="0,0,0,8" Foreground="{StaticResource Brush.TextSecondary}"
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                       Text="Loading elections..." />

                <!-- CARD LIST -->
                <ListBox Grid.Row="2" Margin="0,20,0,0"
                     ItemsSource="{Binding Core.UnfinishedElections}"
                     SelectedItem="{Binding Core.SelectedUnfinishedElection, Mode=TwoWay}"
                     BorderThickness="0"
                     Background="Transparent"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                    <!-- Remove default ListBox chrome -->
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,0,0,12"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Outer"
                                            Background="Transparent"
                                            CornerRadius="12">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Outer" Property="Opacity" Value="0.98"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Outer" Property="Opacity" Value="1"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>

                    <!-- Card UI -->
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <!-- Card -->
                                <Border x:Name="Card"
                                    Style="{StaticResource Card}"
                                    Padding="18"
                                    CornerRadius="14">

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="14"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- HEADER -->
                                        <TextBlock FontSize="18"
                           FontWeight="SemiBold"
                           Text="{Binding ElectionId, StringFormat=Election No: {0}}"/>

                                        <!-- CONTENT -->
                                        <Grid Grid.Row="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock FontSize="14"
                                   Foreground="{StaticResource Brush.TextSecondary}"
                                   Text="Seats"/>
                                                <TextBlock FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="{Binding Seats}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1">
                                                <TextBlock FontSize="14"
                                   Foreground="{StaticResource Brush.TextSecondary}"
                                   Text="Filled"/>
                                                <TextBlock FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="{Binding SeatsDisplay}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2">
                                                <TextBlock FontSize="14"
                                   Foreground="{StaticResource Brush.TextSecondary}"
                                   Text="Quota"/>
                                                <TextBlock FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="{Binding Quota}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <!-- Selected outline -->
                                <Border x:Name="SelectedRing"
                                    CornerRadius="14"
                                    BorderThickness="2"
                                    BorderBrush="{StaticResource Brush.TextSecondary}"
                                    Opacity="0"
                                    IsHitTestVisible="False"/>
                            </Grid>

                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}"
                     Value="True">
                                    <Setter TargetName="SelectedRing" Property="Opacity" Value="1"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource PrimaryButton}" MinWidth="220"
                        Content="Select election" Command="{Binding SelectAndContinueCommand}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>

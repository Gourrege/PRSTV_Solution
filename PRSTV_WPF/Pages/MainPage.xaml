<Page x:Class="PRSTV_WPF.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      FontSize="16">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Nav bar -->
            <RowDefinition Height="*"/>
            <!-- Page content -->
        </Grid.RowDefinitions>

        <!-- NAV BAR -->
        <Border Grid.Row="0"
                Background="#1F2937"
                Padding="12"
                BorderBrush="#111827"
                BorderThickness="0,0,0,1">

            <DockPanel LastChildFill="True">

                <!-- App title -->
                <TextBlock Text="PRS TV"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="White"
                           DockPanel.Dock="Left"
                           Margin="0,0,30,0"/>

                <!-- Navigation buttons -->
                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Left">

                    <Button Content="Count Menu"
                            Width="140"
                            Margin="0,0,10,0"
                            Click="CountMenu_Click"/>

                    <Button Content="Create Election"
                            Width="160"
                            Click="CreateElection_Click"/>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- MAIN PAGE CONTENT -->
        <Grid Grid.Row="1">
            <TextBlock Text="Main page content goes here"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       FontSize="24"
                       Foreground="Gray"/>
        </Grid>
    </Grid>
</Page>

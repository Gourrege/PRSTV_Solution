<Page x:Class="PRST_XAML.Pages.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="{StaticResource Brush.WindowBackground}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock FontSize="28" FontWeight="SemiBold" Text="PR-STV Counting" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="{StaticResource Brush.TextSecondary}"
                       TextWrapping="Wrap"
                       Text="Start a new election or resume an unfinished one. The counting logic and database behavior are unchanged." />
        </StackPanel>

        <Border Grid.Row="1"
                Style="{StaticResource Card}"
                MaxWidth="720"
                HorizontalAlignment="Center"
                Margin="0,16,22,0"
                Grid.RowSpan="2"
                Width="520">
            <StackPanel>
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="What would you like to do?" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="{StaticResource Brush.TextSecondary}"
                           TextWrapping="Wrap"
                           Text="You can start from fresh ballots (new election) or pick up from where an earlier run left off."/>

                <StackPanel Margin="0,16,0,0" Orientation="Horizontal">
                    <Button Style="{StaticResource PrimaryButton}"
                            Margin="0,0,12,0"
                            Content="Start new election"
                            Click="StartNewElection_Click" />

                    <Button Style="{StaticResource SecondaryButton}"
                            Content="Resume election"
                            Click="ResumeElection_Click" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
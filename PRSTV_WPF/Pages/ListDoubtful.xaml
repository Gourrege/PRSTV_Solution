<Page x:Class="PRSTV_WPF.Pages.ListDoubtful"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PRSTV_WPF.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      FontSize="16"
      Title="ListDoubtful">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Doubtful Ballots"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Margin="0,0,0,10"/>

        <DataGrid x:Name="BallotGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  MouseDoubleClick="BallotGrid_MouseDoubleClick"
                  Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="100"/>
                <DataGridTextColumn Header="Random Ballot Id" Binding="{Binding RandomBallotId}" Width="160"/>
                <DataGridTextColumn Header="Box Location" Binding="{Binding BoxLocation}" Width="*"/>
                <DataGridTextColumn Header="Ballot State" Binding="{Binding BallotState}" Width="140"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="2"
                   Text="Double-click a ballot to open details."
                   Foreground="Gray"/>
    </Grid>
</Page>

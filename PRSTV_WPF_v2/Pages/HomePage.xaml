<Page x:Class="PRSTV_WPF_v2.Pages.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PRSTV_WPF_v2.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="HomePage">

    <StackPanel Margin="24">
        <TextBlock FontSize="22" Text="Home"/>

        <Button Margin="0,16,0,0"
                Content="Start New Election"
                Click="StartNewElection_Click"/>

        <Button Margin="0,8,0,0"
                Content="Choose Election"
                Click="ChooseElection_Click"/>
    </StackPanel>
</Page>
